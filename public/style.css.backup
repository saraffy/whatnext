@import url('https://fonts.googleapis.com/css2?family=Arimo:ital,wght@0,400;0,500;0,600;0,700;1,400&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap');

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'EB Garamond', Georgia, serif;
  background: #FBF7F0;
  color: #1a1a1a;
  line-height: 1.6;
  min-height: 100vh;
}

.container {
  max-width: 700px;
  margin: 0 auto;
  padding: 2rem 1.5rem;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

h1, h2, h3 {
  font-family: 'Arimo', Arial, sans-serif;
}

h1 {
  font-size: 2rem;
  margin-bottom: 0.5rem;
  font-weight: 600;
  color: #1a1a1a;
}

.subtitle {
  color: #5a5a5a;
  font-size: 0.95rem;
  margin-bottom: 2rem;
}

input[type="text"],
input[type="text"]:focus {
  width: 100%;
  padding: 1rem;
  margin-bottom: 1.5rem;
  background: #FBF7F0;
  border: 2px solid #D0C8BC;
  border-radius: 8px;
  color: #1a1a1a;
  font-size: 1rem;
  transition: border-color 0.2s;
  outline: none;
}

input[type="text"]:focus {
  border-color: #2d2d2d;
}

button {
  font-family: 'Arimo', Arial, sans-serif;
  padding: 0.75rem 1.5rem;
  background: #2d2d2d;
  color: #FBF7F0;
  border: none;
  border-radius: 6px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s, opacity 0.2s;
}

button:hover {
  background: #1a1a1a;
}

button:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.examples {
  color: #8a8a8a;
  font-size: 0.9rem;
  margin-bottom: 1rem;
}

.examples span {
  display: inline-block;
  margin-right: 0.5rem;
}

/* Quick-start chips */
.quick-goals {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 2rem;
}

.quick-goals span {
  color: #5a5a5a;
  font-size: 0.9rem;
  font-weight: 600;
  font-family: 'Arimo', Arial, sans-serif;
}

.quick-goal-chip {
  font-family: 'Arimo', Arial, sans-serif;
  padding: 0.5rem 1.25rem;
  background: #EEE8DE;
  border: 2px solid #D0C8BC;
  color: #1a1a1a;
  border-radius: 20px;
  font-size: 0.9rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
}

.quick-goal-chip:hover {
  border-color: #2d2d2d;
  color: #2d2d2d;
  transform: translateY(-1px);
}

/* Goal summary box */
.goal-summary-box {
  background: #EEE8DE;
  border: 2px solid #D0C8BC;
  border-radius: 8px;
  padding: 2rem;
  margin-bottom: 2rem;
}

.goal-text {
  font-family: 'Arimo', Arial, sans-serif;
  font-size: 1.3rem;
  font-weight: 600;
  color: #2d2d2d;
  margin-bottom: 1rem;
}

.summary-text {
  color: #5a5a5a;
  line-height: 1.8;
  margin-bottom: 1.5rem;
  font-size: 0.95rem;
}

.encouragement-text {
  color: #6bcf7f;
  font-size: 1rem;
  font-weight: 600;
  font-style: italic;
}

/* Pathway cards */
.pathways-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
  margin-bottom: 2rem;
}

.pathway-card {
  background: #1a1a1a;
  border: 2px solid #333;
  border-radius: 8px;
  padding: 1.5rem;
  cursor: pointer;
  transition: all 0.2s;
}

.pathway-card:hover {
  border-color: #4f8ef7;
  background: #222;
  transform: translateY(-2px);
}

.pathway-emoji {
  font-size: 2.5rem;
  margin-bottom: 0.5rem;
  display: block;
}

.pathway-title {
  font-size: 1.3rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.pathway-description {
  color: #aaa;
  font-size: 0.95rem;
}

/* Duration cards */
.duration-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.duration-card {
  background: #1a1a1a;
  border: 2px solid #333;
  border-radius: 8px;
  padding: 2rem;
  cursor: pointer;
  transition: all 0.2s;
  text-align: center;
}

.duration-card:hover {
  border-color: #4f8ef7;
  background: #222;
  transform: translateY(-2px);
}

.duration-emoji {
  font-size: 3rem;
  margin-bottom: 1rem;
  display: block;
}

.duration-title {
  font-size: 1.2rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
  color: #e8e8e8;
}

.duration-description {
  color: #aaa;
  font-size: 0.85rem;
  line-height: 1.5;
}

/* Duration tabs */
.duration-tabs {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 2rem;
  border-bottom: 2px solid #333;
}

.duration-tab {
  padding: 0.75rem 1.5rem;
  background: transparent;
  border: none;
  border-bottom: 3px solid transparent;
  color: #aaa;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.duration-tab:hover {
  color: #4f8ef7;
}

.duration-tab.active {
  color: #4f8ef7;
  border-bottom-color: #4f8ef7;
}

/* Calendar section */
.calendar-section {
  margin-bottom: 2rem;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
  color: #999;
  font-size: 0.95rem;
}

.zoom-controls {
  display: flex;
  gap: 0.5rem;
  align-items: center;
}

.zoom-btn {
  font-size: 0.85rem;
  padding: 0.35rem 0.75rem;
  font-weight: 600;
  background: #4f8ef7;
  color: #fff;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  transition: background 0.2s;
}

.zoom-btn:hover {
  background: #3d7dd4;
}

.zoom-btn-out {
  background: #555;
}

.zoom-btn-out:hover {
  background: #666;
}

.period-calendar {
  display: grid;
  gap: 0.75rem;
  margin-bottom: 2rem;
}

.cal-cell {
  background: #1a1a1a;
  border: 2px solid #333;
  border-radius: 6px;
  padding: 1rem;
  cursor: pointer;
  transition: all 0.2s;
  text-align: center;
  position: relative;
  min-height: 60px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.cal-cell:hover {
  border-color: #4f8ef7;
}

.cal-cell.active {
  background: #4f8ef7;
  border-color: #4f8ef7;
  color: #fff;
}

.cal-cell.active .cal-cell-label {
  color: #fff;
}

.cal-cell.done {
  border-color: #6bcf7f;
}

.cal-cell-label {
  font-size: 0.85rem;
  font-weight: 500;
  color: #aaa;
}

.cal-cell-check {
  font-size: 1.2rem;
  color: #6bcf7f;
  margin-top: 0.25rem;
}

.roadmap-content {
  margin-top: 2rem;
}

.day-theme {
  font-size: 1.3rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
  color: #4f8ef7;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.task-help-legend {
  color: #555;
  font-size: 0.8rem;
  margin-bottom: 0.75rem;
  font-style: italic;
  padding-left: 0.25rem;
}

.task-item {
  display: flex;
  gap: 1rem;
  background: #1a1a1a;
  padding: 1rem;
  border-radius: 6px;
  border: 1px solid #333;
  align-items: flex-start;
  position: relative;
}

.help-task-btn {
  width: 28px;
  height: 28px;
  padding: 0;
  border-radius: 50%;
  background: #1e3a6e;
  color: #7fb3f5;
  font-size: 0.9rem;
  font-weight: 600;
  border: 1px solid #4f8ef7;
  cursor: pointer;
  flex-shrink: 0;
  transition: all 0.2s;
  margin-top: 2px;
}

.help-task-btn:hover {
  background: #4f8ef7;
  border-color: #4f8ef7;
  color: #fff;
}

.task-item input[type="checkbox"] {
  width: 20px;
  height: 20px;
  margin-top: 2px;
  cursor: pointer;
  accent-color: #4f8ef7;
  flex-shrink: 0;
}

.task-item input[type="checkbox"]:checked + .task-text {
  color: #666;
  text-decoration: line-through;
}

.task-text {
  flex: 1;
  color: #e8e8e8;
  transition: color 0.2s;
}

.task-meta {
  display: flex;
  gap: 0.5rem;
  margin-top: 0.5rem;
}

.task-duration {
  display: inline-block;
  background: #4f8ef7;
  color: #fff;
  padding: 0.25rem 0.75rem;
  border-radius: 12px;
  font-size: 0.8rem;
  font-weight: 600;
}

.task-type {
  display: inline-block;
  background: #333;
  color: #aaa;
  padding: 0.25rem 0.75rem;
  border-radius: 12px;
  font-size: 0.8rem;
}

.stuck-button {
  background: #666;
}

.stuck-button:hover {
  background: #777;
}

.next-day-button {
  background: #4f8ef7;
}

.next-day-button:hover {
  background: #3d7dd4;
}

.loading {
  text-align: center;
  color: #4f8ef7;
  font-weight: 600;
}

.error {
  background: #3d1f1f;
  border: 1px solid #8b3333;
  color: #ff6b6b;
  padding: 1rem;
  border-radius: 6px;
  margin-bottom: 1rem;
}

/* Loading spinner */
.spinner {
  display: inline-block;
  width: 16px;
  height: 16px;
  border: 2px solid #666;
  border-top-color: #4f8ef7;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
  margin-right: 0.5rem;
  vertical-align: middle;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-container {
  text-align: center;
  padding: 3rem 2rem;
  color: #4f8ef7;
  font-weight: 600;
  font-size: 1.1rem;
}

.loading-container .spinner {
  width: 24px;
  height: 24px;
  display: block;
  margin: 0 auto 1rem;
}

/* Confetti */
#confetti {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 9999;
  overflow: hidden;
}

.confetti-piece {
  position: absolute;
  width: 10px;
  height: 10px;
  background: #4f8ef7;
  border-radius: 50%;
  top: -10px;
}

.confetti-piece:nth-child(odd) {
  background: #ff6b9d;
  animation: fall-left 3s ease-in forwards;
}

.confetti-piece:nth-child(even) {
  background: #ffd93d;
  animation: fall-right 3s ease-in forwards;
}

.confetti-piece:nth-child(3n) {
  background: #6bcf7f;
}

.confetti-piece:nth-child(4n) {
  background: #ff6b9d;
}

@keyframes fall-left {
  to {
    transform: translateY(100vh) translateX(-100px) rotateZ(720deg);
    opacity: 0;
  }
}

@keyframes fall-right {
  to {
    transform: translateY(100vh) translateX(100px) rotateZ(720deg);
    opacity: 0;
  }
}

/* Celebration message */
.celebration-message {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #4f8ef7;
  color: white;
  padding: 2rem 3rem;
  border-radius: 12px;
  font-size: 1.3rem;
  font-weight: 600;
  z-index: 10000;
  animation: popUp 0.3s ease-out, fadeOut 0.5s ease-out 2.5s forwards;
  box-shadow: 0 8px 32px rgba(79, 142, 247, 0.3);
}

@keyframes popUp {
  from {
    transform: translate(-50%, -50%) scale(0.5);
    opacity: 0;
  }
  to {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }
}

@keyframes fadeOut {
  from {
    opacity: 1;
  }
  to {
    opacity: 0;
  }
}

/* Help Panel */
.help-panel {
  position: fixed;
  right: -400px;
  top: 0;
  width: 400px;
  height: 100vh;
  background: #1a1a1a;
  border-left: 2px solid #333;
  z-index: 9998;
  transition: right 0.3s ease;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

.help-panel.open {
  right: 0;
}

.help-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem;
  border-bottom: 2px solid #333;
}

.help-panel-header h3 {
  margin: 0;
  color: #4f8ef7;
  font-size: 1.2rem;
}

.help-close {
  width: 32px;
  height: 32px;
  padding: 0;
  background: #333;
  border: none;
  color: #aaa;
  font-size: 1.5rem;
  cursor: pointer;
  border-radius: 4px;
  transition: background 0.2s;
}

.help-close:hover {
  background: #444;
}

.help-panel-content {
  padding: 1.5rem;
  flex: 1;
}

.help-steps {
  margin-bottom: 1.5rem;
}

.help-steps strong {
  color: #e8e8e8;
  font-size: 0.95rem;
  display: block;
  margin-bottom: 0.5rem;
}

.help-steps ol {
  margin-left: 1.5rem;
  color: #ccc;
  line-height: 1.8;
}

.help-steps li {
  margin-bottom: 0.5rem;
}

.help-resources strong {
  color: #e8e8e8;
  font-size: 0.95rem;
  display: block;
  margin-bottom: 0.75rem;
}

.resource-card {
  display: flex;
  gap: 0.75rem;
  background: #222;
  padding: 0.75rem;
  border-radius: 6px;
  margin-bottom: 0.75rem;
  border: 1px solid #333;
}

.resource-card span {
  font-size: 1.2rem;
  flex-shrink: 0;
  margin-top: 2px;
}

.resource-title {
  color: #e8e8e8;
  font-weight: 500;
  font-size: 0.9rem;
  margin-bottom: 0.25rem;
}

.resource-desc {
  color: #999;
  font-size: 0.8rem;
  margin-bottom: 0.5rem;
  line-height: 1.4;
}

.resource-link {
  color: #4f8ef7;
  font-size: 0.8rem;
  text-decoration: none;
  cursor: pointer;
}

.resource-link:hover {
  text-decoration: underline;
}

/* Modal */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10001;
}

.modal-content {
  background: #1a1a1a;
  border-radius: 12px;
  padding: 2.5rem;
  max-width: 600px;
  width: 90%;
  max-height: 90vh;
  overflow-y: auto;
  position: relative;
  border: 2px solid #333;
}

.modal-close {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: #333;
  border: none;
  color: #e8e8e8;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  font-size: 1.5rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}

.modal-close:hover {
  background: #444;
}

.modal-content h2 {
  margin-bottom: 1rem;
  color: #4f8ef7;
  font-size: 1.5rem;
}

.modal-content p {
  color: #ccc;
  line-height: 1.8;
  margin-bottom: 1rem;
}

/* Responsive */
@media (max-width: 600px) {
  .container {
    padding: 1.5rem 1rem;
  }

  h1 {
    font-size: 1.5rem;
  }

  .duration-grid {
    grid-template-columns: 1fr;
  }

  .period-calendar {
    gap: 0.5rem;
  }

  .cal-cell {
    padding: 0.75rem;
    min-height: 50px;
    font-size: 0.8rem;
  }

  .cal-cell-label {
    font-size: 0.75rem;
  }

  .duration-tabs {
    flex-wrap: wrap;
  }

  .duration-tab {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
  }
}
